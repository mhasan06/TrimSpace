generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  address           String?
  phone             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  isActive          Boolean            @default(false)
  category          String?            @default("BARBER")
  templateId        String?            @default("LUXURY")
  abn               String?            @default("00 000 000 000")
  shopImage         String?
  customerPhotos    String[]           @default([])
  description       String?
  galleryImages     String[]           @default([])
  enabledFeatures   Json?              @default("[\"OVERVIEW\", \"SERVICES\", \"CUSTOMERS\", \"ROSTER\", \"REPORTS\", \"LEDGER\", \"SETTINGS\"]")
  accountNumber     String?
  bankName          String?
  bsb               String?
  businessName      String?
  country           String?            @default("Australia")
  phoneCode         String?            @default("+61")
  state             String?
  street            String?
  suburb            String?
  website           String?
  maxBarbers        Int                @default(3)
  appointments      Appointment[]
  bankHistory       BankHistory[]
  businessHours     BusinessHours[]
  favorites         Favorite[]
  giftCards         GiftCard[]
  alerts            MerchantAlert[]
  reviews           Review[]
  scheduleOverrides ScheduleOverride[]
  services          Service[]
  settlements       Settlement[]
  staffSchedules    StaffSchedule[]
  staffShifts       StaffShift[]
  supportTickets    SupportTicket[]
  users             User[]
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  name              String?
  password          String?
  role              String          @default("CUSTOMER")
  tenantId          String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  username          String?         @unique
  phone             String?
  isActive          Boolean         @default(true)
  avatarUrl         String?
  bio               String?
  gender            String?
  state             String?
  suburb            String?
  street            String?
  emailVerified     DateTime?
  verificationToken String?
  barberJobs        Appointment[]   @relation("BarberAppointments")
  appointments      Appointment[]   @relation("CustomerAppointments")
  favorites         Favorite[]
  reviewsReceived   Review[]        @relation("BarberReviews")
  reviewsGiven      Review[]        @relation("CustomerReviews")
  staffSchedules    StaffSchedule[]
  staffShifts       StaffShift[]
  tenant            Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services          Service[]       @relation("ServiceToUser")
}

model BankHistory {
  id            String   @id @default(cuid())
  tenantId      String
  bankName      String?
  bsb           String?
  accountNumber String?
  changedBy     String?
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Service {
  id              String        @id @default(cuid())
  name            String
  durationMinutes Int
  price           Float
  tenantId        String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  isActive        Boolean       @default(true)
  description     String?
  appointments    Appointment[]
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  barbers         User[]        @relation("ServiceToUser")
}

model BusinessHours {
  id          String   @id @default(cuid())
  dayOfWeek   Int
  openTime    String
  closeTime   String
  lunchStart  String?
  lunchEnd    String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  activeStaff Int      @default(1)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ScheduleOverride {
  id        String   @id @default(cuid())
  date      String
  reason    String?
  isClosed  Boolean  @default(true)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Appointment {
  id                    String        @id @default(cuid())
  startTime             DateTime
  endTime               DateTime
  status                String        @default("PENDING")
  customerId            String
  barberId              String
  serviceId             String
  tenantId              String
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  paymentMethod         String        @default("CASH")
  paymentStatus         String        @default("UNPAID")
  invoiceUrl            String?
  amountPaidGift        Float         @default(0)
  amountPaidStripe      Float         @default(0)
  emailSent             Boolean       @default(false)
  giftCardId            String?
  stripePaymentIntentId String?
  settlementId          String?
  bookingGroupId        String?
  cancellationFee       Float         @default(0)
  disputeReason         String?
  disputeResolutionMemo String?
  disputeResolvedAt     DateTime?
  disputeStatus         String?
  isDisputed            Boolean       @default(false)
  disputeResolvedBy     String?
  platformFeeFlat       Float         @default(0.80)
  platformFeeRate       Float         @default(0.017)
  barber                User          @relation("BarberAppointments", fields: [barberId], references: [id], onDelete: Cascade)
  customer              User          @relation("CustomerAppointments", fields: [customerId], references: [id], onDelete: Cascade)
  giftCard              GiftCard?     @relation(fields: [giftCardId], references: [id])
  service               Service       @relation(fields: [serviceId], references: [id])
  settlement            Settlement?   @relation(fields: [settlementId], references: [id])
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  disputeNotes          DisputeNote[]
  review                Review?
}

model DisputeNote {
  id            String      @id @default(cuid())
  appointmentId String
  content       String
  authorName    String
  authorRole    String
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model GiftCard {
  id              String        @id @default(cuid())
  code            String        @unique
  initialValue    Float
  balance         Float
  recipientEmail  String?
  isActive        Boolean       @default(true)
  tenantId        String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  stripeSessionId String?       @unique
  appointments    Appointment[]
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model MerchantAlert {
  id        String   @id @default(cuid())
  type      String
  message   String
  isRead    Boolean  @default(false)
  tenantId  String
  createdAt DateTime @default(now())
  metadata  Json?
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Settlement {
  id            String        @id @default(cuid())
  tenantId      String
  amount        Float
  grossAmount   Float
  feeAmount     Float
  status        String        @default("OUTSTANDING")
  weekLabel     String
  startDate     DateTime
  endDate       DateTime
  adminComments String?
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appointments  Appointment[]
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PlatformSettings {
  id                      String    @id @default("platform_global")
  defaultPlatformFee      Float     @default(0.02)
  updatedAt               DateTime  @updatedAt
  platformName            String    @default("Antigravity Platform")
  platformAbl             String    @default("00 000 000 000")
  platformAddress         String?
  platformEmail           String?
  platformPhone           String?
  defaultFeeEffectiveFrom DateTime?
  bookingPolicy           String?   @default("A valid credit card is required to secure your booking. Priority fees may apply for peak times.")
  cancellationPolicy      String?   @default("All cancellations must be made at least 24 hours in advance to avoid a cancellation fee.")
  penaltyLongRate         Float     @default(0.0)
  penaltyLongThreshold    Int       @default(48)
  penaltyMidRate          Float     @default(0.2)
  penaltyShortRate        Float     @default(1.0)
  penaltyShortThreshold   Int       @default(24)
}

model PlatformFeeSchedule {
  id            String   @id @default(cuid())
  feePercentage Float
  effectiveFrom DateTime
  createdAt     DateTime @default(now())
}

model Review {
  id            String      @id @default(cuid())
  rating        Int
  comment       String?
  isPublic      Boolean     @default(true)
  appointmentId String      @unique
  tenantId      String
  customerId    String
  barberId      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  barber        User        @relation("BarberReviews", fields: [barberId], references: [id], onDelete: Cascade)
  customer      User        @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model GlobalSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  category  String?  @default("GENERAL")
  updatedAt DateTime @updatedAt
}

model SupportTicket {
  id        String           @id @default(cuid())
  subject   String
  category  String           @default("GENERAL")
  status    String           @default("OPEN")
  priority  String           @default("NORMAL")
  tenantId  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  SupportMessage[]
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SupportMessage {
  id         String        @id @default(cuid())
  ticketId   String
  senderId   String
  senderRole String
  content    String
  createdAt  DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model StaffSchedule {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  dayOfWeek Int
  startTime String   @default("09:00")
  endTime   String   @default("17:00")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek])
}

model StaffShift {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  date      String
  startTime String?
  endTime   String?
  isDayOff  Boolean  @default(false)
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
