generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql" 
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String?
  phone     String?
  abn       String?  @default("00 000 000 000")
  isActive  Boolean  @default(false)
  category  String?  @default("BARBER") // BARBER, SALON, SPA
  templateId String? @default("LUXURY") // LUXURY, VINTAGE, MINIMAL
  shopImage  String?
  galleryImages String[] @default([])
  customerPhotos String[] @default([])
  description String? @db.Text
  enabledFeatures Json? @default("[\"OVERVIEW\", \"LEDGER\", \"COMMS\", \"REPORTS\", \"SERVICES\", \"ROSTER\", \"CUSTOMERS\", \"SETTINGS\", \"SUPPORT\", \"PAYMENTS\"]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  services          Service[]
  businessHours     BusinessHours[]
  appointments      Appointment[]
  scheduleOverrides ScheduleOverride[]
  giftCards         GiftCard[]
  alerts            MerchantAlert[]
  settlements       Settlement[]
  reviews           Review[]
  favorites         Favorite[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?  @unique
  phone     String?
  name      String?
  password  String?  
  role      String   @default("CUSTOMER") // CUSTOMER, ADMIN, BARBER
  tenantId  String?
  bio       String? @db.Text
  avatarUrl String?
  suburb    String?
  state     String?
  gender    String?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[] @relation("CustomerAppointments")
  barberJobs   Appointment[] @relation("BarberAppointments")
  
  reviewsGiven    Review[] @relation("CustomerReviews")
  reviewsReceived Review[] @relation("BarberReviews")
  favorites       Favorite[]
}

model Service {
  id              String   @id @default(cuid())
  name            String
  description     String?
  isActive        Boolean  @default(true)
  durationMinutes Int
  price           Float
  tenantId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}


model BusinessHours {
  id        String   @id @default(cuid())
  dayOfWeek Int      // 0 = Sunday, 1 = Monday, etc.
  openTime  String   // HH:mm (e.g. 09:00)
  closeTime String   // HH:mm (e.g. 18:00)
  lunchStart String? // HH:mm Optional lunch break start
  lunchEnd   String? // HH:mm Optional lunch break end
  activeStaff Int    @default(1) // Controls parallel constraint
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ScheduleOverride {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD
  reason    String?  // e.g. "Christmas Eve"
  isClosed  Boolean  @default(true) // Entire day closed?
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Appointment {
  id         String   @id @default(cuid())
  startTime  DateTime
  endTime    DateTime
  status     String   @default("PENDING") 
  customerId String
  barberId   String
  serviceId  String
  tenantId   String
  paymentMethod String @default("CASH") // CASH, CARD_ONLINE, CARD_INSTORE
  paymentStatus String @default("UNPAID") // UNPAID, PAID, REFUNDED
  invoiceUrl    String?
  emailSent      Boolean  @default(false)
  amountPaidStripe Float  @default(0)
  amountPaidGift   Float  @default(0)
  giftCardId    String?
  stripePaymentIntentId String?
  bookingGroupId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer User    @relation("CustomerAppointments", fields: [customerId], references: [id], onDelete: Cascade)
  barber   User    @relation("BarberAppointments", fields: [barberId], references: [id], onDelete: Cascade)
  service  Service @relation(fields: [serviceId], references: [id])
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  giftCard GiftCard? @relation(fields: [giftCardId], references: [id])
  
  settlementId String?
  settlement   Settlement? @relation(fields: [settlementId], references: [id])
  
  review       Review?
}

model GiftCard {
  id            String   @id @default(cuid())
  code          String   @unique // The redemption code (e.g. CARD-XXXX-YYYY)
  initialValue  Float
  balance       Float
  recipientEmail String?
  isActive      Boolean  @default(true)
  stripeSessionId String? @unique
  tenantId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}

model MerchantAlert {
  id        String   @id @default(cuid())
  type      String   // BOOKING_CONFIRMED, BOOKING_CANCELLED
  message   String
  metadata  Json?    // Added for interactive links (e.g., {"date": "2024-04-12", "appointmentId": "..."})
  isRead    Boolean  @default(false)
  tenantId  String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Settlement {
  id              String   @id @default(cuid())
  tenantId        String
  amount          Float    // Net Amount (Gross - Fee)
  grossAmount     Float    // Total charged to customers
  feeAmount       Float    // Platform's cut
  status          String   @default("OUTSTANDING") // OUTSTANDING, SETTLED, INVESTIGATION, DISPUTE
  weekLabel       String   // e.g. "Week 15 - 2026"
  startDate       DateTime
  endDate         DateTime
  adminComments   String?  @db.Text
  metadata        Json?    // For audit history (status changes, timestamps)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
}

model PlatformSettings {
  id                 String   @id @default("platform_global")
  defaultPlatformFee Float    @default(0.02)
  defaultFeeEffectiveFrom DateTime?
  platformName       String   @default("Antigravity Platform")
  platformAbl        String   @default("00 000 000 000")
  platformAddress    String?
  platformPhone      String?
  platformEmail      String?
  updatedAt          DateTime @updatedAt
}

model PlatformFeeSchedule {
  id            String   @id @default(cuid())
  feePercentage Float
  effectiveFrom DateTime
  createdAt     DateTime @default(now())
}

model Review {
  id            String   @id @default(cuid())
  rating        Int      // 1 to 5
  comment       String?  @db.Text
  isPublic      Boolean  @default(true)
  
  appointmentId String   @unique
  tenantId      String
  customerId    String
  barberId      String
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      User        @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)
  barber        User        @relation("BarberReviews", fields: [barberId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}